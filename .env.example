# Copy to `.env` and fill in. `.env` is gitignored; never commit real secrets.
#
# These variables are read by example agents under packages/python/examples/
# and by the Friday daemon (see https://github.com/friday-platform/friday-studio
# for the full list).

# ---- LLM providers (configure at least one) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ---- Optional integrations used by example agents ----

# GitHub — used by examples/claude-code-agent and examples/bb-agent
GH_TOKEN=

# Jira — used by examples/jira-agent
JIRA_API_TOKEN=
JIRA_EMAIL=
JIRA_BASE_URL=

# ---- Daemon connection (defaults shown) ----
# FRIDAY_DAEMON_URL=http://localhost:8080
# FRIDAY_NATS_URL=nats://localhost:4222
