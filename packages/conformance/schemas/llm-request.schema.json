{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LlmRequest",
  "description": "Request payload for the llmGenerate host capability",
  "type": "object",
  "required": ["messages"],
  "properties": {
    "model": {
      "type": "string",
      "description": "Model identifier (e.g., 'anthropic:claude-sonnet-4-5')"
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "object", "additionalProperties": true }
              }
            ]
          }
        },
        "additionalProperties": false
      },
      "description": "Conversation messages (min 1)"
    },
    "max_tokens": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Maximum tokens to generate"
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2,
      "description": "Sampling temperature (0-2)"
    },
    "output_schema": {
      "type": "object",
      "additionalProperties": true,
      "description": "JSON Schema for structured output generation"
    },
    "provider_options": {
      "type": "object",
      "additionalProperties": true,
      "description": "Provider-specific options passed through to the model"
    }
  },
  "additionalProperties": false
}
