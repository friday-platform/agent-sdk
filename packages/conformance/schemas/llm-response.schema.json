{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LlmResponse",
  "description": "Response payload from the llmGenerate host capability",
  "type": "object",
  "required": ["model", "usage", "finish_reason"],
  "properties": {
    "text": {
      "type": "string",
      "description": "Generated text (present for text generation)"
    },
    "object": {
      "description": "Structured output object (present for object generation)"
    },
    "model": {
      "type": "string",
      "description": "Model identifier used for generation"
    },
    "usage": {
      "type": "object",
      "required": ["prompt_tokens", "completion_tokens"],
      "properties": {
        "prompt_tokens": {
          "type": "number",
          "description": "Number of tokens in the prompt"
        },
        "completion_tokens": {
          "type": "number",
          "description": "Number of tokens in the completion"
        }
      },
      "additionalProperties": false
    },
    "finish_reason": {
      "type": "string",
      "description": "Reason generation stopped (e.g., 'stop', 'length')"
    }
  },
  "additionalProperties": false
}
